#!/usr/bin/env bash
#
# Pre-commit hook: lints only the files staged for this commit (Go + web).
# Install it with `make hooks`. Bypass in a pinch with `git commit --no-verify`.
#
# Note: checks reflect the working-tree contents of staged files, not a pristine
# staged snapshot — keep partially-staged files in mind.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"
fail=0

# --- Go: gofmt + go vet when any *.go file is staged ---
go_files=$(git diff --cached --name-only --diff-filter=ACM -- '*.go')
if [ -n "$go_files" ]; then
  unformatted=$(gofmt -l $go_files)
  if [ -n "$unformatted" ]; then
    echo "gofmt needed on:"
    echo "$unformatted"
    fail=1
  fi
  echo "Running go vet…"
  go vet -tags unit ./... || fail=1
fi

# --- Web: eslint when any staged web/ TS/TSX file changes ---
web_files=$(git diff --cached --name-only --diff-filter=ACM -- 'web/*.ts' 'web/*.tsx' | sed 's#^web/##')
if [ -n "$web_files" ]; then
  echo "Running eslint…"
  ( cd web && npx eslint $web_files ) || fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo ""
  echo "Pre-commit checks failed. Fix the issues above, or bypass with 'git commit --no-verify'."
  exit 1
fi
